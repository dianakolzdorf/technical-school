                        <p class="text-muted">Срок обучения: 3 года</p>
                        <span class="badge bg-success">30 мест</span>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3 mb-4">
                <div class="card text-center h-100">
                    <div class="card-body">
                        <i class="fas fa-paint-brush fa-3x text-primary mb-3"></i>
