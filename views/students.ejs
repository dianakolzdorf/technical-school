<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Просмотр студента</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .student-photo-large {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">Техникум</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Главная</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">О техникуме</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contacts">Контакты</a></li>
                    <li class="nav-item"><a class="nav-link" href="/students">Студенты</a></li>
                    <li class="nav-item"><a class="nav-link" href="/teachers">Преподаватели</a></li>
                </ul>
                <ul class="navbar-nav">
                    <% if (user && user.userId) { %>
                        <li class="nav-item">
                            <span class="nav-link text-white">
                                <i class="fas fa-user"></i> <%= user.userName %>
                                <% if (user.userRole === 'admin') { %>
                                    <span class="badge bg-warning text-dark">Админ</span>
                                <% } %>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-light btn-sm" href="/logout">Выйти</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-light btn-sm me-2" href="/login">Вход</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-light btn-sm" href="/register">Регистрация</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h3 class="mb-0"><i class="fas fa-user-graduate"></i> Просмотр студента</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 text-center">
                        <img src="<%= student.photo || '/uploads/default-avatar.jpg' %>" 
                             class="student-photo-large" 
                             alt="Фото студента">
                    </div>
                    <div class="col-md-9">
                        <table class="table table-bordered">
                             <tr><th style="width: 200px;">ID:</th><td><%= student.id %></td></tr>
                             <tr><th>Студенческий ID:</th><td><%= student.student_id %></td></tr>
                             <tr><th>Имя:</th><td><%= student.first_name %></td></tr>
                             <tr><th>Фамилия:</th><td><%= student.last_name %></td></tr>
                             <tr><th>Группа:</th><td><%= student.group_name %></td></tr>
                             <tr><th>Email:</th><td><%= student.email || '-' %></td></tr>
                             <tr><th>Дата рождения:</th><td><%= student.birth_date %></td></tr>
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/students" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Назад к списку
                    </a>
                    <% if (isAdmin) { %>
                        <a href="/students/edit/<%= student.id %>" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Редактировать
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
