cat > views/students.ejs << 'EOF'
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Список студентов</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .table th { background-color: #0d6efd; color: white; }
        .action-btn { margin: 0 2px; }
        .student-photo {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 50%;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">Техникум</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Главная</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">О техникуме</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contacts">Контакты</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/students">Студенты</a></li>
                    <li class="nav-item"><a class="nav-link" href="/teachers">Преподаватели</a></li>
                </ul>
                <ul class="navbar-nav">
                    <% if (user && user.userId) { %>
                        <li class="nav-item">
                            <span class="nav-link text-white">
                                <i class="fas fa-user"></i> <%= user.userName %>
                                <% if (user.userRole === 'admin') { %>
                                    <span class="badge bg-warning text-dark">Админ</span>
                                <% } %>
                            </span>
                        </li>
                        <li class="nav-item"><a class="nav-link btn btn-outline-light btn-sm" href="/logout">Выйти</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link btn btn-outline-light btn-sm me-2" href="/login">Вход</a></li>
                        <li class="nav-item"><a class="nav-link btn btn-light btn-sm" href="/register">Регистрация</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Список студентов</h1>
            <% if (isAdmin) { %>
                <a href="/students/add" class="btn btn-success">
                    <i class="fas fa-plus"></i> Добавить студента
                </a>
            <% } %>
        </div>
        
        <% if (students && students.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover">
                    <thead>
                         <th>ID</th>
                         <th>Студенческий ID</th>
                         <th>Фото</th>
                         <th>Имя</th>
                         <th>Фамилия</th>
                         <th>Группа</th>
                         <th>Email</th>
                         <th>Дата рождения</th>
                         <th>Действия</th>
                    </thead>
                    <tbody>
                        <% students.forEach(student => { %>
                         <td><%= student.id %></td>
                         <td><%= student.student_id %></td>
                         <td>
                            <img src="<%= student.photo || '/uploads/default-avatar.jpg' %>" 
                                 class="student-photo" 
                                 alt="Фото студента">
                         </td>
                         <td><%= student.first_name %></td>
                         <td><%= student.last_name %></td>
                         <td><%= student.group_name %></td>
                         <td><%= student.email || '-' %></td>
                         <td><%= student.birth_date %></td>
                         <td>
                            <a href="/students/<%= student.id %>" class="btn btn-sm btn-info action-btn" title="Просмотр">
                                <i class="fas fa-eye"></i>
                            </a>
                            <% if (isAdmin) { %>
                                <a href="/students/edit/<%= student.id %>" class="btn btn-sm btn-warning action-btn" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form action="/students/delete/<%= student.id %>" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-sm btn-danger action-btn" title="Удалить" onclick="return confirm('Вы уверены?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            <% } %>
                         </td>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="alert alert-info">
                <h4 class="alert-heading">Нет студентов!</h4>
                <p>В базе данных пока нет студентов.</p>
            </div>
        <% } %>
        
        <div class="mt-3">
            <a href="/" class="btn btn-secondary">На главную</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
EOF
